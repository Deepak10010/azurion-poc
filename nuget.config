<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Scope this repo to the public NuGet feed only, so it builds independently
       of any machine-level private feeds. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
